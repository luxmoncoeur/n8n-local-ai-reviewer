      "id": "f8dcd722-5edd-4e6f-8687-1799edb26694",
      "name": "Ollama Chat Model",
      "credentials": {
        "ollamaApi": {
          "id": "Ui9yIPy8Cqb0KEqe",
          "name": "Ollama account"
        }
      }
    }
  ],
